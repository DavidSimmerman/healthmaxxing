# Drizzle / Postgres connection
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Bearer token for the /api/* endpoints hit by Claude Code (leave blank in dev to skip auth)
API_TOKEN=

# App password. Legacy homegrown auth — gates the dashboard login (/login) and
# the homegrown OAuth consent screen (/authorize) for the Claude connector. Used
# ONLY when KEYCLOAK_ISSUER is unset (see below). When set without Keycloak, all
# pages and same-origin API routes require a login session; when unset, the app
# is open (dev convenience).
MCP_AUTH_PASSWORD=

# ── Keycloak (single IdP for dashboard login + the Claude.ai MCP connector) ───
# When KEYCLOAK_ISSUER is set, the app uses Keycloak instead of the homegrown
# password/AS flow: /login redirects to Keycloak, /mcp validates Keycloak-issued
# JWTs, and the OAuth protected-resource metadata points Claude at Keycloak.
# Leave unset to keep the legacy homegrown flow.
#
# Realm issuer URL (no trailing slash). Dev compose serves this at :8080.
KEYCLOAK_ISSUER="http://localhost:8080/realms/health"
# Confidential client for the browser login flow (auth code + PKCE).
KEYCLOAK_CLIENT_ID="health-dashboard-web"
KEYCLOAK_CLIENT_SECRET="dev-web-secret-change-me"
# Secret used to sign the app's own session cookie (any long random string).
# Rotating it invalidates all existing dashboard sessions.
SESSION_SECRET="dev-session-secret-change-me-please"

# ── Production (Coolify) ────────────────────────────────────────────────────
# Public origin of the deployed app. adapter-node needs this behind a reverse
# proxy for correct URLs, form actions, and the OAuth metadata documents.
# ORIGIN="https://health.example.com"

# IANA timezone whose calendar day defines "today". Defaults to America/New_York.
# APP_TZ=America/New_York

# ── Fitbit nightly sync, via the Google Health API ──────────────────────────
# The legacy Fitbit Web API was retired (Sept 2026); Fitbit data is now read
# through Google's Health API with Google OAuth 2.0. One-time setup:
#  1. console.cloud.google.com → create a project; enable the "Health API".
#  2. OAuth consent screen: User type "External"; add yourself under "Test users"
#     (testing mode allows up to 100 users without app verification). Add scopes:
#       https://www.googleapis.com/auth/googlehealth.sleep.readonly
#       https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly
#  3. Credentials → OAuth client ID → "Web application".
#     Authorized redirect URI:  https://<your-host>/api/integrations/fitbit/callback
#     Put the client id/secret below.
#  4. Connect once (signed in as the owner Google account):
#       https://<your-host>/api/integrations/fitbit/authorize?token=<API_TOKEN>
#  5. Confirm the response schema, then trust it:
#       curl -X POST -H "Authorization: Bearer $API_TOKEN" -H 'Content-Type: application/json' \
#            -d '{"debug":true}' https://<your-host>/api/integrations/fitbit/sync
#  6. Daily cron pulls last night's sleep + sleep-derived vitals:
#       0 9 * * * curl -fsS -X POST -H "Authorization: Bearer $API_TOKEN" https://<your-host>/api/integrations/fitbit/sync
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
