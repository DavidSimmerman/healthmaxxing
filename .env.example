# Drizzle / Postgres connection
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Bearer token for the /api/* endpoints hit by Claude Code (leave blank in dev to skip auth)
API_TOKEN=

# App password. Gates BOTH the dashboard login (/login) and the OAuth consent
# screen (/authorize) for the Claude connector. REQUIRED in production — when
# set, all pages and same-origin API routes require a login session; when unset,
# the app is open (dev convenience).
MCP_AUTH_PASSWORD=

# ── Production (Coolify) ────────────────────────────────────────────────────
# Public origin of the deployed app. adapter-node needs this behind a reverse
# proxy for correct URLs, form actions, and the OAuth metadata documents.
# ORIGIN="https://health.example.com"

# IANA timezone whose calendar day defines "today". Defaults to America/New_York.
# APP_TZ=America/New_York
